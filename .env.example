# .env.example

# FastAPI Configuration
PROJECT_NAME="FastPresensi"
VERSION="1.0.0"
API_V1_STR="/api/v1"

# Security
# make sure to change the secret key!
# You can generate one using: openssl rand -hex 32
SECRET_KEY="your-super-secret-key-here"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=10080  

# PostgreSQL Database Configuration
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="your_database_password_here"
POSTGRES_SERVER="localhost"
POSTGRES_PORT="5432"
POSTGRES_DB="fastpresensi"

# SMTP Configuration (optional — jika tidak diisi, password tetap digenerate & dikembalikan di response admin)
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM_EMAIL=""

# Frontend API Base URL
# local: http://localhost:8000/api/v1
# production: https://api.rasyalghifari.my.id/api/v1
API_BASE_URL="http://localhost:8000/api/v1"
